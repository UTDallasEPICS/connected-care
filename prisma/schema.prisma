generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.db"
}

model User {
  id              String           @id @default(uuid())
  fName           String
  mInit           String?
  lName           String
  email           String?          @unique
  phone           String           @unique
  whatsApp        String?          @unique
  contactPref     ContactType      @default(EMAIL)
  type            UserType?
  NonEmployee     NonEmployee?
  Sessions        Session[]
  Specializations Specialization[] @relation("SpecializationToUser")
  loggedInRequests LoggedInRequest[]
}

model NonEmployee {
  id           String       @id @unique
  dob          DateTime
  gender       Gender
  streetName   String
  streetNum    Int
  buildingNum  Int?
  postCode     Int
  PostCodeCity PostCodeCity @relation(fields: [postCode], references: [postCode])
  User         User         @relation(fields: [id], references: [id], onDelete: Cascade)
  Patient      Patient?
  Children     Patient[]    @relation("parent")
}

model PostCodeCity {
  postCode Int           @id @unique @default(autoincrement())
  city     String
  person   NonEmployee[]
}

model Patient {
  id              String           @id @unique
  identification  String           @unique
  diagnosed       Boolean
  sponsorId       String?
  ContactForm     ContactForm?
  MedicalRecords  MedicalRecord[]
  Sponsor         Sponsor?         @relation(fields: [sponsorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  User            NonEmployee      @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  ProgressReports Report[]
  Appointments    SessionPatient[]
  Parents         NonEmployee[]    @relation(name: "parent")
  TherapyNotes    TherapyNote[]
}

model Specialization {
  id         String @id @default(uuid())
  name       String @unique
  Therapists User[] @relation("SpecializationToUser")
}

model Session {
  id            String           @id @default(uuid())
  time          DateTime         @default(now())
  duration      Int
  comment       String?
  maxAttendance Int              @default(1)
  typeId        String
  therapistId   String
  Therapist     User             @relation(fields: [therapistId], references: [id])
  Type          SessionType      @relation(fields: [typeId], references: [id])
  Patients      SessionPatient[]

  @@unique([time, therapistId])
}

model SessionType {
  id       String    @id @default(uuid())
  name     String    @unique
  color    Color
  Sessions Session[]
}

model SessionPatient {
  sessionId String
  patientId String
  paid      Boolean @default(false)
  Patient   Patient @relation(fields: [patientId], references: [id])
  Session   Session @relation(fields: [sessionId], references: [id])

  @@id([sessionId, patientId])
}

model MedicalRecord {
  id        String  @id @default(uuid())
  data      String
  patientId String
  Patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Sponsor {
  id       String    @id @default(uuid())
  name     String
  contact  String
  Patients Patient[]
}

model Report {
  id        String       @id @default(uuid())
  date      DateTime     @default(now())
  patientId String
  Patient   Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Questions ReportData[]
}

model ReportData {
  reportId String
  question String
  answer   String
  Report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@id([reportId, question])
}

model ContactForm {
  id            String           @id @default(uuid())
  nationality   String
  returnPatient Boolean
  wantsEval     Boolean
  insurance     InsuranceCompany
  comment       String?
  status        Status           @default(PROCESSING)
  patientId     String           @unique
  Patient       Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model TherapyNote {
  id Int @id @default(autoincrement())

  patientId String
  Patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  therapyType String

  otherTherapies String?

  objectivesDate DateTime?

  reinforcersUsed String?
  reinforcersDate DateTime?

  familyRecommendations     String?
  familyRecommendationsDate DateTime?

  goalsAchieved     String
  goalsAchievedDate DateTime?

  progressNotes     String
  progressNotesDate DateTime?

  nextSessionObjectives     String
  nextSessionObjectivesDate DateTime?

  incidents     String?
  incidentsDate DateTime?

  generalObservations     String
  generalObservationsDate DateTime?

  groupRecommendationParents String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  objectives TherapyNoteObjective[]
}

model TherapyNoteObjective {
  id Int @id @default(autoincrement())

  therapyNoteId Int
  TherapyNote   TherapyNote @relation(fields: [therapyNoteId], references: [id], onDelete: Cascade)

  goalKey   String?
  goalLabel String
  details   String? // therapist’s text for this specific goal
}

enum ContactType {
  EMAIL
  PHONE
  WHATS_APP
}

enum UserType {
  ADMIN
  USER_SERVICE
  THERAPIST
  EVALUATOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum InsuranceCompany {
  SENASA_CONTRIBUTIVO
  SENASA_SUBSIDIADO
  ARS_HUMANO
  MAPFRE
  LA_MONUMENTAL
  ARS_UNIVERSAL
  ARS_META_SALUD
  ARS_PLAN_SALUD_BANCO_CENTRAL
  RENACER
  OTRO
}

enum Color {
  BLUE
  GREEN
  ORANGE
  PURPLE
  RED
  TEAL
  YELLOW
}

enum Status {
  PROCESSING
  SCHEDULING
  COMPLETED
}

model Request {
  id                        Int      @id @default(autoincrement())
  firstName                 String
  middleName                String?
  lastName                  String
  email                     String
  phone                     String
  whatsapp                  String
  idNumber                  String
  services                  String   // store selected services as JSON or CSV
  createdAt                 DateTime @default(now())
}

model LoggedInRequest {
  id        Int      @id @default(autoincrement())
  services  String   // store selected services as CSV or JSON
  createdAt DateTime @default(now())
  userId    String
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  
}
